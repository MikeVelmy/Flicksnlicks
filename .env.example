# Paystack API keys — get these from your Paystack dashboard (Settings > API Keys & Webhooks)
# Secret key is used server-side only (API routes). Never expose it to the client.
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public key is safe to expose to the client — used to build the Paystack payment page.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
